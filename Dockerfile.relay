FROM golang:1.24-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/relay ./cmd/relay

FROM alpine:3.20
RUN adduser -D -H app
USER app
COPY --from=builder /out/relay /relay
EXPOSE 4001/tcp 4001/udp
ENTRYPOINT ["/relay"]
